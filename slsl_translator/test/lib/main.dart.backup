                            ],
                          ),
                        ),

                      const SizedBox(height: 20),

                      // Control buttons
                      Row(
                        mainAxisAlignment: MainAxisAlignment.center,
                        children: [
                          if (!_isCapturing) ...[
                            ElevatedButton.icon(
                              onPressed: _startCapture,
                              icon: const Icon(Icons.play_arrow, size: 28),
                              label: const Text(
                                "START",
                                style: TextStyle(fontSize: 18),
                              ),
